generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum RequestStatus {
  PENDING
  CONFIRMED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum RouteStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RouteStopStatus {
  PENDING
  ARRIVED
  COMPLETED
  SKIPPED
}

enum NotificationType {
  EMAIL
  PUSH
}

enum NotificationStatus {
  SCHEDULED
  SENT
  FAILED
}

enum PreferenceType {
  WEEKENDS_ONLY
  WEEKDAYS_ONLY
  MORNINGS_ONLY
  AFTERNOONS_ONLY
  AFTER_HOUR
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  phoneNumber String?
  name        String
  role        Role     @default(USER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  addresses      Address[]
  pickupRequests PickupRequest[]
  adminRequests  PickupRequest[] @relation("AdminCreatedRequests")
  notifications  Notification[]
}

model District {
  id       String  @id @default(uuid())
  name     String  @unique
  city     String
  region   String?
  isActive Boolean @default(true)

  addresses  Address[]
  routes     Route[]
  neighbors  DistrictNeighbor[] @relation("DistrictNeighbors")
  neighborOf DistrictNeighbor[] @relation("NeighborDistricts")
}

model DistrictNeighbor {
  id                 String @id @default(uuid())
  districtId         String
  neighborDistrictId String

  district         District @relation("DistrictNeighbors", fields: [districtId], references: [id])
  neighborDistrict District @relation("NeighborDistricts", fields: [neighborDistrictId], references: [id])

  @@unique([districtId, neighborDistrictId])
}

model Address {
  id              String  @id @default(uuid())
  userId          String
  districtId      String
  city            String
  street          String
  buildingNumber  String
  entrance        String?
  floor           String?
  apartment       String?
  additionalNotes String?
  latitude        Float?
  longitude       Float?

  user           User            @relation(fields: [userId], references: [id])
  district       District        @relation(fields: [districtId], references: [id])
  pickupRequests PickupRequest[]
}

model PickupRequest {
  id                   String        @id @default(uuid())
  userId               String
  createdByAdminId     String?
  addressId            String
  status               RequestStatus @default(PENDING)
  preferredNote        String?
  estimatedTotalWeight Float?
  estimatedTotalVolume Float?
  scheduledDate        DateTime?
  scheduledTimeFrom    String?
  scheduledTimeTo      String?
  routeId              String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user                    User                     @relation(fields: [userId], references: [id])
  createdByAdmin          User?                    @relation("AdminCreatedRequests", fields: [createdByAdminId], references: [id])
  address                 Address                  @relation(fields: [addressId], references: [id])
  route                   Route?                   @relation(fields: [routeId], references: [id])
  items                   RequestItem[]
  availabilitySlots       AvailabilitySlot[]
  availabilityPreferences AvailabilityPreference[]
  routeStops              RouteStop[]
  notifications           Notification[]
}

model ElectronicsItem {
  id            String  @id @default(uuid())
  name          String  @unique
  category      String
  defaultWeight Float
  defaultVolume Float
  isActive      Boolean @default(true)

  requestItems RequestItem[]
}

model RequestItem {
  id                String  @id @default(uuid())
  requestId         String
  electronicsItemId String
  quantity          Int
  estimatedWeight   Float?
  estimatedVolume   Float?
  notes             String?

  request         PickupRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  electronicsItem ElectronicsItem @relation(fields: [electronicsItemId], references: [id])
}

model AvailabilitySlot {
  id            String   @id @default(uuid())
  requestId     String
  availableDate DateTime
  timeFrom      String
  timeTo        String
  isFlexible    Boolean  @default(false)

  request PickupRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model AvailabilityPreference {
  id             String         @id @default(uuid())
  requestId      String
  preferenceType PreferenceType
  value          String?

  request PickupRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model Vehicle {
  id                 String  @id @default(uuid())
  registrationNumber String  @unique
  name               String
  maxWeightCapacity  Float
  maxVolumeCapacity  Float
  isActive           Boolean @default(true)

  routes Route[]
}

model Team {
  id          String  @id @default(uuid())
  name        String
  phoneNumber String?
  isActive    Boolean @default(true)

  members TeamMember[]
  routes  Route[]
}

model TeamMember {
  id          String  @id @default(uuid())
  teamId      String
  fullName    String
  phoneNumber String?
  role        String

  team Team @relation(fields: [teamId], references: [id])
}

model Route {
  id                   String      @id @default(uuid())
  teamId               String?
  vehicleId            String?
  routeDate            DateTime
  districtId           String
  status               RouteStatus @default(PLANNED)
  totalEstimatedWeight Float?
  totalEstimatedVolume Float?
  createdAt            DateTime    @default(now())

  team     Team?     @relation(fields: [teamId], references: [id])
  vehicle  Vehicle?  @relation(fields: [vehicleId], references: [id])
  district District  @relation(fields: [districtId], references: [id])
  stops    RouteStop[]
  requests PickupRequest[]
}

model RouteStop {
  id                 String          @id @default(uuid())
  routeId            String
  requestId          String
  stopOrder          Int
  plannedArrivalTime String?
  actualArrivalTime  String?
  status             RouteStopStatus @default(PENDING)

  route   Route         @relation(fields: [routeId], references: [id])
  request PickupRequest @relation(fields: [requestId], references: [id])
}

model Notification {
  id           String             @id @default(uuid())
  userId       String
  requestId    String?
  type         NotificationType
  message      String
  scheduledFor DateTime?
  sentAt       DateTime?
  status       NotificationStatus @default(SCHEDULED)

  user    User           @relation(fields: [userId], references: [id])
  request PickupRequest? @relation(fields: [requestId], references: [id])
}
